{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "memorylink",
  "compatibility_date": "2025-12-13",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "MYSQL_HOST": "127.0.0.1",
    "MYSQL_PORT": "3306",
    "MYSQL_USER": "root",
    "MYSQL_DATABASE": "memorylink",
    "OPENAI_MODEL": "gpt-5.2"
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "memorylink-files",
      "preview_bucket_name": "memorylink-files-preview"
    }
  ]
}