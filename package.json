{
  "name": "memorylink",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:python": "cd python-api && python3 -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name memorylink",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name memorylink",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || fuser -k 8000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "test:python": "curl http://localhost:8000/health",
    "python:install": "pip3 install -r python-api/requirements.txt",
    "python:start": "cd python-api && python3 main.py",
    "db:mysql:setup": "node scripts/setup-mysql.mjs"
  },
  "dependencies": {
    "hono": "^4.11.0",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
